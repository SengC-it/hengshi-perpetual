# Supabase server-only credentials. Never expose the secret key to a browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-secret-key

# Vercel sends this value as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=replace-with-at-least-32-random-characters

# Gmail SMTP app password. Use a Google app password, not the account password.
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
ALERT_EMAIL_TO=your-account@gmail.com

# Optional scanner tuning.
SCAN_CONCURRENCY=12
BINANCE_REQUEST_TIMEOUT_MS=15000
